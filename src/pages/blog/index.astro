---
import Layout from "../../layouts/Layout.astro";
import "../../styles/globals.css";
import { posts } from "../../data/posts.js";

const sorted = [...posts].sort((a, b) => (a.date < b.date ? 1 : -1));

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Blog",
	name: "Blog de aquí nace — Finanzas comunitarias en Perú",
	description:
		"Artículos sobre UNICAs, bancas comunales, ahorro grupal y herramientas de finanzas en Perú.",
	url: "https://aquinace.com/blog",
	blogPost: sorted.map((p) => ({
		"@type": "BlogPosting",
		headline: p.title,
		description: p.description,
		datePublished: p.date,
		url: "https://aquinace.com/blog/" + p.slug,
	})),
};
---

<Layout
	title="Blog de aquí nace — Finanzas comunitarias, UNICAs y banca comunal en Perú"
	description="Aprende sobre UNICAs, bancas comunales, ahorro grupal y las mejores herramientas de finanzas en Perú. Guías prácticas para tu asociación o comunidad."
	keywords="blog finanzas comunitarias, qué es una UNICA, qué es una banca comunal, herramientas de finanzas Perú, ahorro grupal, educación financiera Perú"
	canonicalPath="/blog"
	jsonLd={jsonLd}
>
	<div class="bg-blobs">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<nav class="navbar">
		<div class="navbar-inner">
			<a href="/" class="navbar-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
			</a>
			<a href="/" class="btn-back">← Inicio</a>
		</div>
	</nav>

	<main class="blog-main">
		<header class="blog-hero">
			<h1>
				Finanzas comunitarias <span class="grad">para el Perú</span>
			</h1>
			<p>
				Todo sobre UNICAs, bancas comunales, ahorro grupal y las mejores
				herramientas de finanzas para tu organización.
			</p>
		</header>

		<div class="blog-grid">
			{
				sorted.map((p) => (
					<a href={`/blog/${p.slug}`} class="blog-card">
						<div class="blog-card-body">
							<div class="blog-meta">
								<span class="blog-cat">{p.category}</span>
								<span class="dot">·</span>
								<span>{p.readingTime} de lectura</span>
							</div>
							<h2>{p.title}</h2>
							<p>{p.description}</p>
							<span class="blog-read">Leer artículo →</span>
						</div>
					</a>
				))
			}
		</div>
	</main>

	<footer class="site-footer">
		<div class="footer-inner">
			<div class="footer-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
				<span class="footer-copy">© 2026 aquí nace. Todos los derechos reservados.</span>
			</div>
			<div class="footer-links">
				<a href="/blog" class="footer-link">Blog</a>
				<a href="/privacidad" class="footer-link">Privacidad</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	@import "../../styles/legal-shared.css";

	/* Brand wordmark (match homepage) */
	.navbar-brand .wordmark { font-size: 1.5rem; }
	.footer-brand .wordmark { font-size: 1.2rem; }
	.navbar-brand .wordmark .wm-a,
	.footer-brand .wordmark .wm-a { color: var(--green-forest); }
	.navbar-brand .wordmark .wm-n,
	.footer-brand .wordmark .wm-n { color: var(--green-bright); }

	.blog-main {
		padding: 128px 16px 80px;
		max-width: 1152px;
		margin: 0 auto;
	}
	.blog-hero {
		text-align: center;
		margin-bottom: 56px;
	}
	.blog-hero h1 {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 800;
		color: #16281c;
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin-bottom: 16px;
	}
	.grad {
		background: linear-gradient(110deg, #2f9e44, #52c06a, #226a38);
		background-size: 200% auto;
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		animation: gradient-shift 6s ease infinite;
	}
	.blog-hero p {
		color: #64748b;
		font-size: 1.0625rem;
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.7;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 28px;
	}
	@media (min-width: 640px) {
		.blog-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 1024px) {
		.blog-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.blog-card {
		display: flex;
		flex-direction: column;
		border-radius: 20px;
		overflow: hidden;
		background: #fff;
		border: 1px solid #e2e8f0;
		text-decoration: none;
		box-shadow: 0 4px 20px rgba(27, 50, 95, 0.04);
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.blog-card:hover {
		transform: translateY(-6px);
		border-color: rgba(0, 135, 122, 0.3);
		box-shadow: 0 26px 50px rgba(0, 135, 122, 0.13);
	}
	.blog-card-body {
		padding: 26px 24px 28px;
		display: flex;
		flex-direction: column;
		flex: 1;
	}
	.blog-meta {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 0.75rem;
		color: #94a3b8;
		margin-bottom: 12px;
	}
	.blog-cat {
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #2f9e44;
	}
	.blog-meta .dot {
		color: #cbd5e1;
	}
	.blog-card h2 {
		font-size: 1.1rem;
		font-weight: 700;
		color: #16281c;
		line-height: 1.3;
		margin-bottom: 10px;
	}
	.blog-card-body p {
		color: #64748b;
		font-size: 0.9rem;
		line-height: 1.6;
		flex: 1;
		margin-bottom: 16px;
	}
	.blog-read {
		color: #2f9e44;
		font-weight: 700;
		font-size: 0.875rem;
	}

	@keyframes gradient-shift {
		0% {
			background-position: 0% 50%;
		}
		50% {
			background-position: 100% 50%;
		}
		100% {
			background-position: 0% 50%;
		}
	}
</style>

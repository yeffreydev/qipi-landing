---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";

const SITE = "https://aquinace.com";
const WA =
	"https://wa.me/51916913623?text=Hola%2C%20quiero%20conocer%20la%20plataforma%20de%20aqu%C3%AD%20nace%20%F0%9F%8C%B1";

const homeJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "aquí nace",
		applicationCategory: "FinanceApplication",
		operatingSystem: "Web, Android, iOS",
		description:
			"Plataforma que conecta a las personas con oportunidades financieras reales y accesibles en Perú. Nosotros ofrecemos la tecnología; tú decides cómo crecer.",
		url: SITE,
		offers: { "@type": "Offer", price: "0", priceCurrency: "PEN" },
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "¿Qué es aquí nace?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "aquí nace es una plataforma que conecta a las personas con oportunidades financieras reales y accesibles. No otorgamos créditos: ofrecemos la tecnología y la red para que gestiones y hagas crecer tus finanzas.",
				},
			},
			{
				"@type": "Question",
				name: "¿aquí nace otorga créditos?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "No. aquí nace es la plataforma tecnológica que conecta a las personas con oportunidades financieras. Nosotros ofrecemos las herramientas y la red; las decisiones financieras las tomas tú.",
				},
			},
			{
				"@type": "Question",
				name: "¿Para quién es aquí nace?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Para emprendedores, familias y comunidades que quieren organizar y hacer crecer sus finanzas con una herramienta cercana y transparente.",
				},
			},
		],
	},
];
---

<Layout
	title="aquí nace — La plataforma que te conecta con más oportunidades financieras"
	description="aquí nace es la plataforma que conecta personas con oportunidades financieras reales y accesibles. No otorgamos créditos: ofrecemos la tecnología y la red para que crezcas."
	keywords="aquí nace, aquinace, plataforma financiera Perú, red financiera, herramienta de finanzas, oportunidades financieras, inclusión financiera, fintech Perú"
	canonicalPath="/"
	jsonLd={homeJsonLd}
>
	<!-- Background decorative elements -->
	<div class="bg-blobs" aria-hidden="true">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<!-- Navigation -->
	<nav class="navbar">
		<div class="navbar-inner">
			<a href="/" class="navbar-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
			</a>
			<div class="navbar-links">
				<a href="#inicio" class="navbar-link">Inicio</a>
				<a href="#nosotros" class="navbar-link">Nosotros</a>
				<a href="#servicios" class="navbar-link">Servicios</a>
				<a href="/blog" class="navbar-link">Blog</a>
				<a href="/token" class="navbar-link">Token</a>
				<a href="#contacto" class="navbar-link">Contacto</a>
			</div>
			<div class="navbar-actions">
				<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow btn-yellow-sm">
					Empieza ahora
				</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero -->
		<section class="hero" id="inicio">
			<div class="hero-grid">
				<div class="hero-copy">
					<h1 class="hero-title">
						Tu red financiera<br />
						para <span class="grad-green">crecer</span> juntos.
					</h1>
					<p class="hero-sub">
						La plataforma que conecta personas con oportunidades
						financieras <strong>reales y accesibles.</strong> Simple,
						cercana y hecha para ti.
					</p>
					<div class="hero-cta">
						<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow">
							Empieza ahora
						</a>
						<a href="#servicios" class="btn-ghost">Conoce más</a>
					</div>
					<div class="hero-trust">
						<span>Sin complicaciones</span>
						<span>·</span>
						<span>Respuesta inmediata</span>
					</div>
				</div>

				<!-- Hero photo -->
				<div class="hero-art">
					<div class="art-ring"></div>
					<div class="hero-photo">
						<img
							src="/hero.jpeg"
							alt="Comunidad usando la plataforma aquí nace para gestionar sus finanzas"
							width="1600"
							height="900"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				</div>
			</div>

			<!-- Value strip -->
			<div class="value-strip">
				<div class="value-item">
					<div class="value-ic ic-green">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
					</div>
					<div>
						<h3>Comunidad</h3>
						<p>Formamos una red de apoyo y confianza.</p>
					</div>
				</div>
				<div class="value-item">
					<div class="value-ic ic-green">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
					</div>
					<div>
						<h3>Crecimiento</h3>
						<p>Soluciones financieras que impulsan tus metas.</p>
					</div>
				</div>
				<div class="value-item">
					<div class="value-ic ic-green">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
					</div>
					<div>
						<h3>Confianza</h3>
						<p>Transparencia y seguridad en cada paso.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Services / Why -->
		<section class="section" id="servicios">
			<div class="container">
				<div class="section-head">
					<h2>¿Por qué <span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>?</h2>
					<p>La plataforma que conecta tus finanzas con más oportunidades. Simple, cercana y transparente.</p>
				</div>

				<div class="cards-grid">
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<h3>Oportunidades a tu alcance</h3>
						<p>Te conectamos con las opciones financieras que se ajustan a ti, en un solo lugar.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
						</div>
						<h3>Rápido y simple</h3>
						<p>Sin trámites eternos. Escríbenos, cuéntanos qué necesitas y avanzamos contigo.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<h3>Red de apoyo</h3>
						<p>No estás solo. Una comunidad y asesores que te acompañan en cada decisión.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
						</div>
						<h3>Crecimiento real</h3>
						<p>Impulsamos tu negocio o proyecto para que cada sol trabaje a tu favor.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<h3>Cercanía</h3>
						<p>Trato humano y directo. Te escuchamos y damos soluciones a tu medida.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
						</div>
						<h3>Seguridad y confianza</h3>
						<p>Transparencia total y tus datos protegidos, desde el primer contacto.</p>
					</article>
				</div>
			</div>
		</section>

		<!-- Dark band: dreams -->
		<section class="band" id="nosotros">
			<div class="band-orb" aria-hidden="true"></div>
			<div class="container band-inner">
				<div class="band-copy">
					<span class="wordmark on-dark band-mark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
					<h2>Juntos, hacemos crecer <span class="grad-yellow">tus sueños.</span></h2>
					<p>La plataforma que organiza y conecta tus finanzas con lo que <strong>realmente importa.</strong></p>
					<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow">Empieza ahora</a>
				</div>
				<div class="band-values">
					<div class="bv">
						<div class="bv-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<span>Cercanía</span>
					</div>
					<div class="bv">
						<div class="bv-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v8m0 0l3-3m-3 3l-3-3M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<span>Oportunidad</span>
					</div>
					<div class="bv">
						<div class="bv-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
						</div>
						<span>Crecimiento</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Steps -->
		<section class="section section-alt">
			<div class="container">
				<div class="section-head">
					<h2>Empieza en <span class="grad-green">3 pasos</span></h2>
					<p>Simple, cercano y sin vueltas. Empieza hoy mismo.</p>
				</div>
				<div class="steps">
					<div class="step">
						<span class="step-n">1</span>
						<h3>Escríbenos</h3>
						<p>Contáctanos por WhatsApp y crea tu cuenta en la plataforma.</p>
					</div>
					<div class="step">
						<span class="step-n">2</span>
						<h3>Explora</h3>
						<p>Accede a la plataforma y descubre las oportunidades que se ajustan a ti.</p>
					</div>
					<div class="step">
						<span class="step-n">3</span>
						<h3>Crece con nosotros</h3>
						<p>Gestiona y haz crecer lo que realmente importa, a tu ritmo.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Final CTA -->
		<section class="cta" id="contacto">
			<div class="cta-card">
				<span class="wordmark cta-mark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
				<h2>¿Listo para dar el primer paso?</h2>
				<p>Escríbenos y empieza a usar la plataforma hoy. <strong>Aquí nace tu próxima oportunidad.</strong></p>
				<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow btn-yellow-lg">
					<svg class="wa-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
					Empieza ahora
				</a>
				<span class="cta-sub">Sin compromisos · Respuesta inmediata</span>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="site-footer">
		<div class="footer-inner">
			<div class="footer-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
			</div>
			<p class="footer-copy">© 2026 aquí nace · Tu red financiera para crecer juntos</p>
			<div class="footer-links">
				<a href="/token" class="footer-link">Token</a>
				<a href="/privacidad" class="footer-link">Política de Privacidad</a>
				<a href={WA} target="_blank" rel="noopener noreferrer" class="footer-link">Contactar por WhatsApp →</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* ===== BACKGROUND BLOBS ===== */
	.bg-blobs {
		position: fixed;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
		z-index: -1;
	}
	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
	}
	.blob-1 {
		top: -12%;
		left: 15%;
		width: 620px;
		height: 620px;
		background: rgba(47, 158, 68, 0.1);
		animation: blob-drift 22s ease-in-out infinite;
	}
	.blob-2 {
		bottom: 10%;
		right: -8%;
		width: 520px;
		height: 520px;
		background: rgba(245, 197, 24, 0.09);
		animation: blob-drift 28s ease-in-out infinite reverse;
	}
	.blob-3 {
		top: 45%;
		left: -8%;
		width: 420px;
		height: 420px;
		background: rgba(28, 90, 48, 0.07);
		animation: blob-drift 25s ease-in-out infinite;
	}

	/* ===== NAVBAR ===== */
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid rgba(28, 90, 48, 0.08);
	}
	.navbar-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 14px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}
	.navbar-brand {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		flex-shrink: 0;
	}
	.navbar-brand img {
		transition: transform 0.3s;
	}
	.navbar-brand:hover img {
		transform: rotate(-6deg) scale(1.06);
	}
	.navbar-brand .wordmark {
		font-size: 1.5rem;
	}
	.navbar-links {
		display: none;
		align-items: center;
		gap: 30px;
	}
	.navbar-link {
		color: var(--green-forest);
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		transition: color 0.25s;
	}
	.navbar-link:hover {
		color: var(--green-bright);
	}
	@media (min-width: 900px) {
		.navbar-links {
			display: flex;
		}
	}

	/* ===== BUTTONS ===== */
	.btn-yellow {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 14px 28px;
		background: var(--yellow);
		color: #3d2c00;
		font-weight: 700;
		border-radius: 9999px;
		font-size: 1rem;
		text-decoration: none;
		border: none;
		transition: all 0.3s;
		box-shadow: 0 8px 22px rgba(245, 197, 24, 0.35);
	}
	.btn-yellow:hover {
		background: #ffd633;
		transform: translateY(-2px);
		box-shadow: 0 14px 32px rgba(245, 197, 24, 0.45);
	}
	.btn-yellow:active {
		transform: translateY(0) scale(0.98);
	}
	.btn-yellow-sm {
		padding: 10px 20px;
		font-size: 0.9rem;
	}
	.btn-yellow-lg {
		padding: 18px 38px;
		font-size: 1.15rem;
	}
	.btn-ghost {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 28px;
		background: transparent;
		color: var(--green-forest);
		font-weight: 700;
		border-radius: 9999px;
		font-size: 1rem;
		text-decoration: none;
		border: 2px solid rgba(28, 90, 48, 0.2);
		transition: all 0.3s;
	}
	.btn-ghost:hover {
		border-color: var(--green);
		background: var(--green-soft);
	}
	.wa-icon {
		width: 22px;
		height: 22px;
	}

	/* ===== GRADIENT TEXT ===== */
	.grad-green {
		background: linear-gradient(110deg, #2f9e44, #52c06a, #1c5a30);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: var(--green);
	}
	.grad-yellow {
		background: linear-gradient(110deg, #ffde59, #f5c518);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		color: var(--yellow);
	}

	/* ===== BADGE ===== */
	.badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 7px 16px;
		border-radius: 9999px;
		background: rgba(47, 158, 68, 0.1);
		border: 1px solid rgba(47, 158, 68, 0.22);
		color: var(--green-800);
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 22px;
	}
	.badge-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--green);
		animation: pulse 2s infinite;
	}

	/* ===== HERO ===== */
	.hero {
		max-width: 1180px;
		margin: 0 auto;
		padding: 130px 24px 40px;
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 1fr;

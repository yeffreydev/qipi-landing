---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";

const SITE = "https://aquinace.com";
const WA =
	"https://wa.me/51916913623?text=Hola%2C%20quiero%20conocer%20la%20plataforma%20de%20aqu%C3%AD%20nace%20%F0%9F%8C%B1";

const homeJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "aquí nace",
		applicationCategory: "FinanceApplication",
		operatingSystem: "Web, Android, iOS",
		description:
			"Plataforma que conecta a las personas con oportunidades financieras reales y accesibles en Perú. Nosotros ofrecemos la tecnología; tú decides cómo crecer.",
		url: SITE,
		offers: { "@type": "Offer", price: "0", priceCurrency: "PEN" },
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "¿Qué es aquí nace?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "aquí nace es una plataforma que conecta a las personas con oportunidades financieras reales y accesibles. No otorgamos créditos: ofrecemos la tecnología y la red para que gestiones y hagas crecer tus finanzas.",
				},
			},
			{
				"@type": "Question",
				name: "¿aquí nace otorga créditos?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "No. aquí nace es la plataforma tecnológica que conecta a las personas con oportunidades financieras. Nosotros ofrecemos las herramientas y la red; las decisiones financieras las tomas tú.",
				},
			},
			{
				"@type": "Question",
				name: "¿Para quién es aquí nace?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Para emprendedores, familias y comunidades que quieren organizar y hacer crecer sus finanzas con una herramienta cercana y transparente.",
				},
			},
		],
	},
];
---

<Layout
	title="aquí nace — La plataforma que te conecta con más oportunidades financieras"
	description="aquí nace es la plataforma que conecta personas con oportunidades financieras reales y accesibles. No otorgamos créditos: ofrecemos la tecnología y la red para que crezcas."
	keywords="aquí nace, aquinace, plataforma financiera Perú, red financiera, herramienta de finanzas, oportunidades financieras, inclusión financiera, fintech Perú"
	canonicalPath="/"
	jsonLd={homeJsonLd}
>
	<!-- Background decorative elements -->
	<div class="bg-blobs" aria-hidden="true">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<!-- Navigation -->
	<nav class="navbar">
		<div class="navbar-inner">
			<a href="/" class="navbar-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
			</a>
			<div class="navbar-links">
				<a href="#inicio" class="navbar-link">Inicio</a>
				<a href="/comunidades-inteligentes" class="navbar-link">Comunidades</a>
				<a href="#nosotros" class="navbar-link">Nosotros</a>
				<a href="#servicios" class="navbar-link">Servicios</a>
				<a href="/blog" class="navbar-link">Blog</a>
				<a href="/token" class="navbar-link">Token</a>
				<a href="#contacto" class="navbar-link">Contacto</a>
			</div>
			<div class="navbar-actions">
				<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow btn-yellow-sm">
					Empieza ahora
				</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero -->
		<section class="hero" id="inicio">
			<div class="hero-stage">
				<h1 class="sr-only">aquí nace — comunidades inteligentes</h1>

				<!-- Hero illustration: comunidades inteligentes (protagonista) -->
				<div class="hero-art">
					<div class="art-ring"></div>
					<svg
						class="hero-illus"
						viewBox="0 0 900 740"
						role="img"
						aria-label="Ilustración de comunidades inteligentes conectadas en una red financiera"
						xmlns="http://www.w3.org/2000/svg"
					>
						<defs>
							<linearGradient id="hi-sky" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0" stop-color="#5b21b6"/>
								<stop offset="0.5" stop-color="#7c3aed"/>
								<stop offset="1" stop-color="#0ea5e9"/>
							</linearGradient>
							<linearGradient id="hi-purple" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0" stop-color="#a78bfa"/>
								<stop offset="0.55" stop-color="#7c3aed"/>
								<stop offset="1" stop-color="#5b21b6"/>
							</linearGradient>
							<linearGradient id="hi-silver" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0" stop-color="#ffffff"/>
								<stop offset="1" stop-color="#cbd5e1"/>
							</linearGradient>
							<linearGradient id="hi-blue" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0" stop-color="#7dd3fc"/>
								<stop offset="1" stop-color="#0284c7"/>
							</linearGradient>
							<radialGradient id="hi-glow" cx="0.5" cy="0.44" r="0.62">
								<stop offset="0" stop-color="#ede9fe"/>
								<stop offset="0.5" stop-color="#f5f3ff"/>
								<stop offset="1" stop-color="#ffffff"/>
							</radialGradient>
							<radialGradient id="hi-hub" cx="0.42" cy="0.36" r="0.75">
								<stop offset="0" stop-color="#c4b5fd"/>
								<stop offset="0.5" stop-color="#7c3aed"/>
								<stop offset="1" stop-color="#5b21b6"/>
							</radialGradient>
							<radialGradient id="hi-core" cx="0.42" cy="0.34" r="0.8">
								<stop offset="0" stop-color="#ffffff"/>
								<stop offset="0.7" stop-color="#f5f3ff"/>
								<stop offset="1" stop-color="#ede9fe"/>
							</radialGradient>
							<linearGradient id="hi-word" x1="0" y1="0" x2="1" y2="0">
								<stop offset="0" stop-color="#5b21b6"/>
								<stop offset="0.32" stop-color="#7c3aed"/>
								<stop offset="0.54" stop-color="#94a3b8"/>
								<stop offset="0.76" stop-color="#38bdf8"/>
								<stop offset="1" stop-color="#0ea5e9"/>
							</linearGradient>
							<filter id="hi-shadow" x="-30%" y="-30%" width="160%" height="160%">
								<feDropShadow dx="0" dy="14" stdDeviation="18" flood-color="#5b21b6" flood-opacity="0.22"/>
							</filter>
						</defs>

						<!-- soft backdrop -->
						<rect x="30" y="24" width="840" height="684" rx="64" fill="url(#hi-glow)"/>
						<circle cx="450" cy="300" r="278" fill="#0ea5e9" opacity="0.06"/>
						<circle cx="450" cy="300" r="206" fill="#7c3aed" opacity="0.06"/>
						<circle cx="450" cy="300" r="134" fill="#5b21b6" opacity="0.05"/>

						<!-- orbit rings -->
						<g fill="none" opacity="0.4">
							<ellipse cx="450" cy="300" rx="340" ry="234" stroke="#a78bfa" stroke-width="1.5" stroke-dasharray="2 13" stroke-linecap="round"/>
							<ellipse cx="450" cy="300" rx="236" ry="164" stroke="#38bdf8" stroke-width="1.5" stroke-dasharray="2 13" stroke-linecap="round"/>
						</g>

						<!-- connection network (with data pulses) -->
						<g class="hi-links" stroke-linecap="round" fill="none">
							<path d="M450 300 L200 150" stroke="url(#hi-sky)" stroke-width="4" opacity="0.5"/>
							<path d="M450 300 L700 150" stroke="url(#hi-sky)" stroke-width="4" opacity="0.5"/>
							<path d="M450 300 L135 340" stroke="url(#hi-sky)" stroke-width="4" opacity="0.5"/>
							<path d="M450 300 L765 340" stroke="url(#hi-sky)" stroke-width="4" opacity="0.5"/>
							<path d="M450 300 L280 528" stroke="url(#hi-sky)" stroke-width="4" opacity="0.5"/>
							<path d="M450 300 L620 528" stroke="url(#hi-sky)" stroke-width="4" opacity="0.5"/>
						</g>
						<g class="hi-flow" fill="#ffffff">
							<circle cx="0" cy="0" r="5"><animateMotion dur="2.6s" repeatCount="indefinite" path="M450 300 L200 150"/></circle>
							<circle cx="0" cy="0" r="5"><animateMotion dur="2.9s" repeatCount="indefinite" path="M450 300 L700 150"/></circle>
							<circle cx="0" cy="0" r="5"><animateMotion dur="3.1s" repeatCount="indefinite" path="M450 300 L135 340"/></circle>
							<circle cx="0" cy="0" r="5"><animateMotion dur="2.7s" repeatCount="indefinite" path="M450 300 L765 340"/></circle>
							<circle cx="0" cy="0" r="5"><animateMotion dur="3.3s" repeatCount="indefinite" path="M450 300 L280 528"/></circle>
							<circle cx="0" cy="0" r="5"><animateMotion dur="3.0s" repeatCount="indefinite" path="M450 300 L620 528"/></circle>
						</g>

						<!-- central hub: núcleo con el logo "aquí nace" -->
						<g class="hi-hub" filter="url(#hi-shadow)">
							<circle cx="450" cy="300" r="118" fill="none" stroke="#a78bfa" stroke-width="2" opacity="0.5" class="hi-pulse-ring"/>
							<!-- orbiting neural nodes on the ring -->
							<g fill="#a78bfa" opacity="0.9">
								<circle cx="450" cy="196" r="6"/>
								<circle cx="540" cy="248" r="6"/>
								<circle cx="540" cy="352" r="6"/>
								<circle cx="450" cy="404" r="6"/>
								<circle cx="360" cy="352" r="6"/>
								<circle cx="360" cy="248" r="6"/>
							</g>
							<!-- glowing outer ring -->
							<circle cx="450" cy="300" r="104" fill="url(#hi-hub)"/>
							<!-- inner light core: logo -->
							<circle cx="450" cy="300" r="90" fill="url(#hi-core)"/>
							<circle cx="450" cy="300" r="90" fill="none" stroke="url(#hi-sky)" stroke-width="3.5" opacity="0.6"/>
							<circle cx="450" cy="300" r="78" fill="none" stroke="#ede9fe" stroke-width="1.5"/>
							<text x="452" y="292" text-anchor="middle" fill="url(#hi-word)" font-family="Fredoka, Arial, sans-serif" font-size="46" font-weight="700" letter-spacing="-1">aquí</text>
							<text x="452" y="342" text-anchor="middle" fill="url(#hi-word)" font-family="Fredoka, Arial, sans-serif" font-size="46" font-weight="700" letter-spacing="-1">nace</text>
						</g>

						<!-- node: smart home (top-left) -->
						<g filter="url(#hi-shadow)" class="hi-float">
							<circle cx="200" cy="150" r="66" fill="url(#hi-silver)"/>
							<!-- wifi over roof: casa inteligente -->
							<g stroke="#38bdf8" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.9">
								<path d="M186 112 a20 20 0 0 1 28 0"/>
								<path d="M193 120 a10 10 0 0 1 14 0"/>
							</g>
							<path d="M166 156 L200 126 L234 156 Z" fill="url(#hi-purple)"/>
							<rect x="176" y="152" width="48" height="42" rx="8" fill="url(#hi-purple)"/>
							<rect x="192" y="166" width="16" height="28" rx="3" fill="#ffffff" opacity="0.92"/>
							<rect x="180" y="160" width="12" height="12" rx="3" fill="#38bdf8"/>
						</g>

						<!-- node: market / negocio (top-right) -->
						<g filter="url(#hi-shadow)" class="hi-float2">
							<circle cx="700" cy="150" r="66" fill="url(#hi-silver)"/>
							<!-- storefront -->
							<rect x="674" y="150" width="52" height="44" rx="7" fill="url(#hi-blue)"/>
							<rect x="690" y="166" width="20" height="28" rx="3" fill="#ffffff" opacity="0.9"/>
							<!-- awning -->
							<path d="M666 132 h68 v10 a8 8 0 0 1 -8 8 h-52 a8 8 0 0 1 -8 -8 Z" fill="url(#hi-purple)"/>
							<g fill="#ffffff" opacity="0.85">
								<rect x="678" y="132" width="11" height="18"/>
								<rect x="700" y="132" width="11" height="18"/>
								<rect x="722" y="132" width="8" height="18"/>
							</g>
						</g>

						<!-- node: comunidad / personas (left) -->
						<g filter="url(#hi-shadow)" class="hi-float">
							<circle cx="135" cy="340" r="70" fill="url(#hi-silver)"/>
							<!-- three people -->
							<circle cx="106" cy="324" r="15" fill="#7c3aed"/>
							<path d="M87 372 a19 21 0 0 1 38 0 Z" fill="#7c3aed"/>
							<circle cx="164" cy="324" r="15" fill="#a78bfa"/>
							<path d="M145 372 a19 21 0 0 1 38 0 Z" fill="#a78bfa"/>
							<circle cx="135" cy="316" r="17" fill="#38bdf8"/>
							<path d="M113 368 a22 24 0 0 1 44 0 Z" fill="#38bdf8"/>
						</g>

						<!-- node: plataforma / app (right) -->
						<g filter="url(#hi-shadow)" class="hi-float2">
							<circle cx="765" cy="340" r="64" fill="url(#hi-silver)"/>
							<rect x="743" y="306" width="44" height="70" rx="11" fill="url(#hi-purple)"/>
							<rect x="749" y="314" width="32" height="54" rx="5" fill="#ffffff"/>
							<!-- heart = comunidad en la app -->
							<path d="M765 344 c-5 -9 -18 -6 -18 4 c0 7 10 13 18 19 c8 -6 18 -12 18 -19 c0 -10 -13 -13 -18 -4 Z" fill="url(#hi-sky)"/>
							<g fill="#a78bfa">
								<circle cx="757" cy="360" r="2.6"/>
								<circle cx="765" cy="360" r="2.6"/>
								<circle cx="773" cy="360" r="2.6"/>
							</g>
						</g>

						<!-- node: crecimiento (bottom-left) -->
						<g filter="url(#hi-shadow)" class="hi-float">
							<circle cx="280" cy="528" r="60" fill="#ffffff"/>
							<circle cx="280" cy="528" r="60" fill="none" stroke="url(#hi-sky)" stroke-width="3" opacity="0.4"/>
							<path d="M250 550 L272 522 L288 538 L312 500" fill="none" stroke="url(#hi-sky)" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M296 500 L312 500 L312 516" fill="none" stroke="#0ea5e9" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
						</g>

						<!-- node: ahorro / coin (bottom-right) -->
						<g filter="url(#hi-shadow)" class="hi-float2">
							<circle cx="620" cy="528" r="60" fill="url(#hi-purple)"/>
							<circle cx="620" cy="528" r="60" fill="none" stroke="#ffffff" stroke-width="4" opacity="0.55"/>
							<text x="620" y="548" text-anchor="middle" fill="#ffffff" font-family="Fredoka, Arial, sans-serif" font-size="48" font-weight="700">S/</text>
						</g>

						<!-- integrated label: Comunidades inteligentes -->
						<g filter="url(#hi-shadow)">
							<rect x="262" y="636" width="376" height="58" rx="29" fill="#ffffff" stroke="#ece7ff" stroke-width="1.5"/>
							<!-- emblema exclusivo: red de comunidad (3 nodos conectados) -->
							<g transform="translate(300 665)">
								<circle cx="0" cy="0" r="16" fill="#f5f3ff" stroke="#ece7ff" stroke-width="1.5"/>
								<g stroke="url(#hi-sky)" stroke-width="2.4" stroke-linecap="round">
									<path d="M0 -8 L7 5"/>
									<path d="M0 -8 L-7 5"/>
									<path d="M-7 5 L7 5"/>
								</g>
								<circle cx="0" cy="-8" r="4" fill="#7c3aed"/>
								<circle cx="7" cy="5" r="4" fill="#0ea5e9"/>
								<circle cx="-7" cy="5" r="4" fill="#38bdf8"/>
							</g>
							<text x="328" y="673" fill="url(#hi-sky)" font-family="Fredoka, Arial, sans-serif" font-size="25" font-weight="700">Comunidades inteligentes</text>
						</g>

						<!-- floating sparks -->
						<g class="hi-spark">
							<circle cx="330" cy="150" r="8" fill="#38bdf8"/>
							<circle cx="575" cy="360" r="7" fill="#a78bfa"/>
							<circle cx="345" cy="420" r="6" fill="#7dd3fc"/>
							<circle cx="600" cy="230" r="6" fill="#5b21b6"/>
							<circle cx="300" cy="300" r="5" fill="#0ea5e9"/>
						</g>
					</svg>
				</div>

				<div class="hero-cta">
					<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow btn-yellow-lg">
						Empieza ahora
					</a>
				</div>
			</div>

			<!-- Value strip -->
			<div class="value-strip">
				<div class="value-item">
					<div class="value-ic ic-green">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
					</div>
					<div>
						<h3>Comunidad</h3>
						<p>Formamos una red de apoyo y confianza.</p>
					</div>
				</div>
				<div class="value-item">
					<div class="value-ic ic-green">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
					</div>
					<div>
						<h3>Crecimiento</h3>
						<p>Soluciones financieras que impulsan tus metas.</p>
					</div>
				</div>
				<div class="value-item">
					<div class="value-ic ic-green">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
					</div>
					<div>
						<h3>Confianza</h3>
						<p>Transparencia y seguridad en cada paso.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Services / Why -->
		<section class="section" id="servicios">
			<div class="container">
				<div class="section-head">
					<h2>¿Por qué <span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>?</h2>
					<p>La plataforma que conecta tus finanzas con más oportunidades. Simple, cercana y transparente.</p>
				</div>

				<div class="cards-grid">
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<h3>Oportunidades a tu alcance</h3>
						<p>Te conectamos con las opciones financieras que se ajustan a ti, en un solo lugar.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
						</div>
						<h3>Rápido y simple</h3>
						<p>Sin trámites eternos. Escríbenos, cuéntanos qué necesitas y avanzamos contigo.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<h3>Red de apoyo</h3>
						<p>No estás solo. Una comunidad y asesores que te acompañan en cada decisión.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
						</div>
						<h3>Crecimiento real</h3>
						<p>Impulsamos tu negocio o proyecto para que cada sol trabaje a tu favor.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<h3>Cercanía</h3>
						<p>Trato humano y directo. Te escuchamos y damos soluciones a tu medida.</p>
					</article>
					<article class="card">
						<div class="card-ic">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
						</div>
						<h3>Seguridad y confianza</h3>
						<p>Transparencia total y tus datos protegidos, desde el primer contacto.</p>
					</article>
				</div>
			</div>

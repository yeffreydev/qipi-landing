---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";

const SITE = "https://qipi.aquinace.com";
const homeJsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "Qipi",
		applicationCategory: "FinanceApplication",
		operatingSystem: "Android, iOS",
		description:
			"App de finanzas comunitarias para gestionar UNICAs, bancas comunales y asociaciones en Perú: aportes, ahorros, préstamos e inversiones.",
		url: SITE,
		offers: { "@type": "Offer", price: "0", priceCurrency: "PEN" },
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "¿Qué es una UNICA?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Una UNICA (Unión de Crédito y Ahorro) es un grupo autogestionado de personas que ahorra en conjunto y se otorga préstamos entre sí con reglas claras, sin intermediarios bancarios.",
				},
			},
			{
				"@type": "Question",
				name: "¿Qué es una banca comunal?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Una banca comunal es un grupo de personas que ahorra y accede a créditos de forma colectiva, respaldándose con una garantía solidaria entre todos sus miembros.",
				},
			},
			{
				"@type": "Question",
				name: "¿Para qué sirve Qipi?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Qipi es una herramienta de finanzas comunitarias en Perú que digitaliza aportes, préstamos, ahorros e inversiones de tu UNICA, banca comunal o asociación en una sola app.",
				},
			},
		],
	},
];
---

<Layout
	title="Qipi — Finanzas comunitarias en Perú | UNICAs y banca comunal"
	description="Qipi es la herramienta de finanzas comunitarias en Perú para gestionar UNICAs, bancas comunales y asociaciones: controla aportes, ahorros, préstamos e inversiones desde una sola app."
	keywords="Qipi, finanzas comunitarias, herramientas de finanzas Perú, qué es una UNICA, qué es una banca comunal, app de ahorro grupal, préstamos comunitarios, gestión de aportes, asociaciones Perú, inclusión financiera"
	canonicalPath="/"
	jsonLd={homeJsonLd}
>
	<!-- Background decorative elements -->
	<div class="bg-blobs">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<!-- Navigation -->
	<nav class="navbar">
		<div class="navbar-inner">
			<a href="/" class="navbar-brand">
				<img src="/logo-icon.svg" alt="Qipi" width="40" height="40" />
				<span>Qipi</span>
			</a>
			<div class="navbar-actions">
				<a href="/blog" class="navbar-link">Blog</a>
				<a
					href="https://wa.me/51916913623?text=%F0%9F%92%9A%20Hola%2C%20quiero%20dar%20el%20primer%20paso%20con%20Qipi%20%F0%9F%9A%80%E2%9C%A8"
					target="_blank"
					rel="noopener noreferrer"
					class="btn-wa-nav"
				>
				<svg class="wa-icon-sm" fill="currentColor" viewBox="0 0 24 24"
					><path
						d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
					></path></svg
				>
				Iniciar ahora
			</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero Section -->
		<section class="hero-section">
			<div class="hero-content">
				<!-- Badge -->
				<div class="badge">
					<span class="badge-dot"></span>
					El inicio de algo grande
				</div>

				<!-- Title -->
				<h1 class="hero-title">
					<span>Transforma tu </span>
					<span class="gradient-text-1">organización</span>
					<br />
					<span>con </span>
					<span class="gradient-text-2">Qipi</span>
				</h1>

				<!-- Subtitle -->
				<p class="hero-subtitle">
					Donde cada aporte suma. Donde cada reunión construye futuro.
					Donde la confianza no se discute… <strong>se siente.</strong
					>
				</p>

				<!-- Video Container -->
				<div class="video-wrapper">
					<div class="video-container">
						<iframe
							src="https://www.youtube.com/embed/NJdPoxVA8WA?si=Hl0huvfJOh21lMVW"
							title="Qipi — Transforma tu organización"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen></iframe>
					</div>
				</div>

				<!-- First CTA Button -->
				<div class="cta-wrapper">
					<a
						href="https://wa.me/51916913623?text=%F0%9F%92%9A%20Hola%2C%20quiero%20dar%20el%20primer%20paso%20con%20Qipi%20%F0%9F%9A%80%E2%9C%A8"
						target="_blank"
						rel="noopener noreferrer"
						id="cta-hero"
						class="btn-wa"
					>
						<svg
							class="wa-icon"
							fill="currentColor"
							viewBox="0 0 24 24"
							><path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
							></path></svg
						>
						Iniciar ahora
					</a>
				</div>

				<!-- Custom hero illustration -->
				<div class="hero-illustration" aria-hidden="true">
					<svg viewBox="0 0 640 380" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
						<defs>
							<linearGradient id="gPhone" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0" stop-color="#1b325f" />
								<stop offset="0.55" stop-color="#00599a" />
								<stop offset="1" stop-color="#00877a" />
							</linearGradient>
							<linearGradient id="gCard" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0" stop-color="#00a894" />
								<stop offset="1" stop-color="#00877a" />
							</linearGradient>
							<linearGradient id="gCoin" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0" stop-color="#ffd66b" />
								<stop offset="1" stop-color="#f0a93c" />
							</linearGradient>
							<filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
								<feDropShadow dx="0" dy="18" stdDeviation="22" flood-color="#1b325f" flood-opacity="0.18"></feDropShadow>
							</filter>
						</defs>

						<circle cx="120" cy="110" r="90" fill="#00877a" opacity="0.08"></circle>
						<circle cx="540" cy="270" r="110" fill="#00599a" opacity="0.07"></circle>

						<g class="il-nodes" stroke="#00a894" stroke-width="2.5" opacity="0.5">
							<line x1="92" y1="92" x2="180" y2="200"></line>
							<line x1="180" y1="200" x2="92" y2="300"></line>
							<line x1="180" y1="200" x2="300" y2="120"></line>
						</g>
						<g class="il-people">
							<circle cx="92" cy="92" r="20" fill="#00599a"></circle>
							<circle cx="92" cy="300" r="18" fill="#00a894"></circle>
							<circle cx="300" cy="120" r="16" fill="#1b325f"></circle>
							<text x="92" y="98" text-anchor="middle" fill="#fff" font-size="18" font-weight="700" font-family="Inter, sans-serif">A</text>
							<text x="92" y="306" text-anchor="middle" fill="#fff" font-size="16" font-weight="700" font-family="Inter, sans-serif">M</text>
							<text x="300" y="125" text-anchor="middle" fill="#fff" font-size="14" font-weight="700" font-family="Inter, sans-serif">J</text>
						</g>

						<g class="il-phone" filter="url(#softShadow)">
							<rect x="210" y="70" width="220" height="280" rx="32" fill="url(#gPhone)"></rect>
							<rect x="222" y="82" width="196" height="256" rx="24" fill="#0f223f"></rect>
							<rect x="238" y="100" width="164" height="92" rx="16" fill="url(#gCard)"></rect>
							<text x="254" y="128" fill="#eafff8" font-size="12" font-family="Inter, sans-serif" font-weight="600">Total invertido</text>
							<text x="254" y="160" fill="#ffffff" font-size="26" font-family="Inter, sans-serif" font-weight="800">S/ 38,510</text>
							<rect x="346" y="108" width="42" height="20" rx="10" fill="#ffffff" opacity="0.22"></rect>
							<text x="367" y="122" text-anchor="middle" fill="#ffffff" font-size="11" font-family="Inter, sans-serif" font-weight="700">+12%</text>
							<g class="il-bars">
								<rect x="250" y="280" width="20" height="34" rx="5" fill="#00a894"></rect>
								<rect x="282" y="262" width="20" height="52" rx="5" fill="#00877a"></rect>
								<rect x="314" y="240" width="20" height="74" rx="5" fill="#00599a"></rect>
								<rect x="346" y="216" width="20" height="98" rx="5" fill="#1b325f"></rect>
							</g>
							<path class="il-line" d="M250 250 L284 234 L316 214 L356 188" stroke="#ffd66b" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
							<circle cx="356" cy="188" r="6" fill="#ffd66b"></circle>
						</g>

						<g class="il-coin il-coin-a">
							<circle cx="470" cy="120" r="34" fill="url(#gCoin)"></circle>
							<circle cx="470" cy="120" r="34" fill="none" stroke="#fff" stroke-opacity="0.4" stroke-width="2"></circle>
							<text x="470" y="128" text-anchor="middle" fill="#7a4a00" font-size="22" font-weight="800" font-family="Inter, sans-serif">S/</text>
						</g>
						<g class="il-coin il-coin-b">
							<circle cx="510" cy="240" r="24" fill="url(#gCoin)"></circle>
							<text x="510" y="247" text-anchor="middle" fill="#7a4a00" font-size="15" font-weight="800" font-family="Inter, sans-serif">S/</text>
						</g>
					</svg>
				</div>
			</div>

			<!-- Scroll indicator -->
			<div class="scroll-indicator">
				<span>Descubre más</span>
				<svg
					width="20"
					height="20"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg
				>
			</div>
		</section>

		<!-- Features Section -->
		<section class="features-section">
			<div class="section-container">
				<div class="section-header">
					<h2>
						¿Qué puedes hacer con <span class="gradient-text-2"
							>Qipi</span
						>?
					</h2>
					<p>
						Organiza, administra y haz crecer tu asociación con
						herramientas profesionales.
					</p>
				</div>

				<div class="features-grid">
					<!-- Feature 1 -->
					<div class="feature-card">
						<div class="feature-icon icon-teal">
							<svg
								width="28"
								height="28"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
								></path></svg
							>
						</div>
						<h3>Organiza a tus miembros</h3>
						<p>
							Crea tu organización desde cero o transforma la que
							ya tienes en algo más sólido y profesional.
						</p>
					</div>

					<!-- Feature 2 -->
					<div class="feature-card">
						<div class="feature-icon icon-blue">
							<svg
								width="28"
								height="28"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
								></path></svg
							>
						</div>
						<h3>Administra el dinero</h3>
						<p>
							Gestiona aportes de forma efectiva y convierte cada
							contribución en crecimiento real para tu grupo.
						</p>
					</div>

					<!-- Feature 3 -->
					<div class="feature-card">
						<div class="feature-icon icon-navy">
							<svg
								width="28"
								height="28"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
								></path></svg
							>
						</div>
						<h3>Accede a préstamos</h3>
						<p>
							Con una estructura clara, tu grupo puede acceder a
							préstamos con cuotas bajas y reglas definidas.
						</p>
					</div>

					<!-- Feature 4 -->
					<div class="feature-card">
						<div class="feature-icon icon-teal">
							<svg
								width="28"
								height="28"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
								></path></svg
							>
						</div>
						<h3>Confianza total</h3>
						<p>
							Cuando hay orden, hay confianza. Cuando hay
							confianza, hay compromiso. Y cuando hay compromiso,
							el crecimiento es inevitable.
						</p>
					</div>

					<!-- Feature 5 -->
					<div class="feature-card">
						<div class="feature-icon icon-blue">
							<svg
								width="28"
								height="28"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
								></path></svg
							>
						</div>
						<h3>Capital en circulación</h3>
						<p>
							Haz que el dinero trabaje para ustedes y no al
							revés. El capital circula y genera oportunidades.
						</p>
					</div>

					<!-- Feature 6 -->
					<div class="feature-card">
						<div class="feature-icon icon-teal-light">
							<svg
								width="28"
								height="28"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
							>
						</div>
						<h3>Empieza desde cualquier punto</h3>
						<p>
							Trae tu grupo actual o crea uno nuevo. Lo importante
							no es el punto de partida, es el potencial que
							pueden desbloquear.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- App Showcase Section -->
		<section class="app-section" id="app">
			<div class="section-container">
				<div class="section-header">
					<div class="badge badge-static">
						<span class="badge-dot"></span>
						La app de Qipi
					</div>
					<h2>
						Todo tu grupo en <span class="gradient-text-2"
							>una sola app</span
						>
					</h2>
					<p>
						Inversiones, billetera, marketplace, noticias y foro.
						Diseñada para que tu organización funcione desde el
						celular.
					</p>
				</div>

				<div class="app-grid">
					<!-- 1. Inversión -->
					<div class="app-card app-card-feature">
						<div class="app-card-text">
							<span class="app-tag app-tag-teal">Inversión</span>
							<h3>Tu inversión, clara y en tiempo real</h3>
							<p>
								Total invertido, acciones, ahorros y préstamos.
								Cada miembro ve cuánto aporta y cuánto crece su
								capital, sin hojas de cálculo.
							</p>
						</div>
						<div class="app-phone">
							<img
								src="/app/inversion-resumen.png"
								alt="Resumen de inversión en la app Qipi"
								loading="lazy"
							/>
						</div>
					</div>

					<!-- 2. Billetera -->
					<div class="app-card">
						<div class="app-phone app-phone-sm">
							<img
								src="/app/billetera-acciones.png"
								alt="Billetera y movimientos de acciones en Qipi"
								loading="lazy"
							/>
						</div>
						<div class="app-card-text">
							<span class="app-tag app-tag-blue">Billetera</span>
							<h3>Cada aporte, registrado</h3>
							<p>
								Acciones, ahorros, préstamos y utilidades con el
								historial completo de movimientos.
							</p>
						</div>
					</div>

					<!-- 3. Marketplace -->
					<div class="app-card">
						<div class="app-phone app-phone-sm">
							<img
								src="/app/marketplace.png"
								alt="Marketplace de la comunidad Qipi"
								loading="lazy"
							/>
						</div>
						<div class="app-card-text">
							<span class="app-tag app-tag-teal-light"
								>Marketplace</span
							>
							<h3>Compra y vende en tu comunidad</h3>
							<p>
								Un espacio seguro para negociar entre miembros
								verificados, con pagos protegidos.
							</p>
						</div>
					</div>

					<!-- 4. Noticias -->
					<div class="app-card">
						<div class="app-phone app-phone-sm">
							<img
								src="/app/noticias.png"
								alt="Noticias de tu comunidad financiera en Qipi"
								loading="lazy"
							/>
						</div>
						<div class="app-card-text">
							<span class="app-tag app-tag-navy">Noticias</span>

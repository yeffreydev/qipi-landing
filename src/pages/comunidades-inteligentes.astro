---
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";

const SITE = "https://aquinace.com";
const WA =
	"https://wa.me/51916913623?text=Hola%2C%20quiero%20crear%20una%20comunidad%20inteligente%20con%20aqu%C3%AD%20nace%20%F0%9F%8C%B1";

const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "WebPage",
		name: "Comunidades Inteligentes — aquí nace",
		description:
			"Con aquí nace creas comunidades inteligentes sin necesidad de tener mucho conocimiento: una economía propia que se diferencia y prospera, herramientas de gestión, academia y más.",
		url: SITE + "/comunidades-inteligentes",
		inLanguage: "es-PE",
	},
	{
		"@context": "https://schema.org",
		"@type": "FAQPage",
		mainEntity: [
			{
				"@type": "Question",
				name: "¿Qué es una comunidad inteligente de aquí nace?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "Es una comunidad —una UNICA, banca comunal, junta o asociación— que gestiona su dinero, sus reglas y su crecimiento con la tecnología de aquí nace. Tiene su propia economía, herramientas digitales, academia de aprendizaje y una red de apoyo, todo en un solo lugar.",
				},
			},
			{
				"@type": "Question",
				name: "¿Necesito conocimientos técnicos o financieros para crearla?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "No. aquí nace está diseñada para que cualquier persona pueda crear y liderar su comunidad sin conocimientos previos. La plataforma guía cada paso, automatiza los cálculos y te acompaña con su academia y su red.",
				},
			},
			{
				"@type": "Question",
				name: "¿Qué hace que la economía de una comunidad inteligente prospere?",
				acceptedAnswer: {
					"@type": "Answer",
					text: "El dinero se queda y circula dentro de la comunidad: los aportes, préstamos e intereses regresan a los propios miembros. Con reglas claras, transparencia total y herramientas que evitan errores, la economía de la comunidad se diferencia de la banca tradicional y crece de forma sostenible.",
				},
			},
		],
	},
];
---

<Layout
	title="Comunidades Inteligentes — Crea la tuya sin conocimientos previos | aquí nace"
	description="Con aquí nace creas comunidades inteligentes sin necesidad de tener mucho conocimiento: una economía propia que se diferencia y prospera, herramientas, academia y una red que te acompaña."
	keywords="comunidades inteligentes, comunidad inteligente Perú, economía comunitaria, crear comunidad, finanzas comunitarias, academia financiera, herramientas de finanzas, aquí nace"
	canonicalPath="/comunidades-inteligentes"
	jsonLd={jsonLd}
>
	<!-- Background decorative elements -->
	<div class="bg-blobs" aria-hidden="true">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<!-- Navigation -->
	<nav class="navbar">
		<div class="navbar-inner">
			<a href="/" class="navbar-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
			</a>
			<div class="navbar-links">
				<a href="/#inicio" class="navbar-link">Inicio</a>
				<a href="/comunidades-inteligentes" class="navbar-link">Comunidades</a>
				<a href="/#servicios" class="navbar-link">Servicios</a>
				<a href="/blog" class="navbar-link">Blog</a>
				<a href="/token" class="navbar-link">Token</a>
			</div>
			<div class="navbar-actions">
				<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow btn-yellow-sm">
					Crea tu comunidad
				</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero -->
		<section class="ci-hero">
			<div class="ci-hero-grid">
				<div class="ci-hero-copy">
					<span class="badge"><span class="badge-dot"></span> Una nueva forma de crecer juntos</span>
					<h1 class="ci-title">
						Crea <span class="grad-green">comunidades inteligentes</span> sin ser un experto.
					</h1>
					<p class="ci-sub">
						Con <span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
						cualquiera puede formar una comunidad que ahorra, presta y crece con orden.
						<strong>Sin conocimientos previos.</strong> Con una economía propia que se diferencia
						y prospera, herramientas, academia y una red que te acompaña.
					</p>
					<div class="ci-cta">
						<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow">
							Crea tu comunidad
						</a>
						<a href="#pilares" class="btn-ghost">Cómo funciona</a>
					</div>
					<div class="ci-trust">
						<span>Sin experiencia técnica</span>
						<span>·</span>
						<span>Te guiamos paso a paso</span>
					</div>
				</div>

				<!-- Illustration -->
				<div class="ci-hero-art">
					<div class="ci-art-ring" aria-hidden="true"></div>
					<svg
						class="ci-illustration"
						viewBox="0 0 520 480"
						role="img"
						aria-label="Ilustración de una comunidad inteligente conectada por aquí nace"
						xmlns="http://www.w3.org/2000/svg"
					>
						<defs>
							<linearGradient id="ci-g-green" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0" stop-color="#52c06a" />
								<stop offset="1" stop-color="#1c5a30" />
							</linearGradient>
							<linearGradient id="ci-g-yellow" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0" stop-color="#ffde59" />
								<stop offset="1" stop-color="#f5c518" />
							</linearGradient>
							<radialGradient id="ci-g-core" cx="0.5" cy="0.4" r="0.7">
								<stop offset="0" stop-color="#52c06a" />
								<stop offset="1" stop-color="#226a38" />
							</radialGradient>
						</defs>

						<!-- soft backdrop -->
						<circle cx="260" cy="230" r="200" fill="#e7f6e9" opacity="0.55" />

						<!-- connection lines -->
						<g class="ci-links" stroke="#2f9e44" stroke-width="2.5" opacity="0.5" fill="none">
							<line x1="260" y1="230" x2="110" y2="120" />
							<line x1="260" y1="230" x2="410" y2="120" />
							<line x1="260" y1="230" x2="90" y2="320" />
							<line x1="260" y1="230" x2="430" y2="320" />
							<line x1="260" y1="230" x2="260" y2="80" />
						</g>

						<!-- central core: aquí nace hub -->
						<g class="ci-core">
							<circle cx="260" cy="230" r="64" fill="url(#ci-g-core)" />
							<circle cx="260" cy="230" r="64" fill="none" stroke="#fff" stroke-width="4" opacity="0.35" />
							<!-- sprout -->
							<path
								d="M260 258 V214"
								stroke="#fff"
								stroke-width="6"
								stroke-linecap="round"
							/>
							<path
								d="M260 224 C244 214 236 198 240 184 C256 188 264 206 260 224 Z"
								fill="#dff3df"
							/>
							<path
								d="M260 214 C276 206 286 190 284 176 C268 178 258 196 260 214 Z"
								fill="#fff"
							/>
						</g>

						<!-- node: person -->
						<g class="ci-node ci-float-a">
							<circle cx="110" cy="120" r="38" fill="#fff" stroke="url(#ci-g-green)" stroke-width="4" />
							<circle cx="110" cy="110" r="12" fill="#2f9e44" />
							<path d="M90 140 a20 16 0 0 1 40 0 Z" fill="#2f9e44" />
						</g>

						<!-- node: coin (economy) -->
						<g class="ci-node ci-float-b">
							<circle cx="410" cy="120" r="38" fill="#fff" stroke="url(#ci-g-yellow)" stroke-width="4" />
							<circle cx="410" cy="120" r="24" fill="url(#ci-g-yellow)" />
							<text x="410" y="129" text-anchor="middle" font-family="Fredoka, sans-serif" font-weight="700" font-size="24" fill="#7a4a00">S/</text>
						</g>

						<!-- node: house (community) -->
						<g class="ci-node ci-float-c">
							<circle cx="90" cy="320" r="38" fill="#fff" stroke="url(#ci-g-green)" stroke-width="4" />
							<path d="M72 322 L90 306 L108 322 V338 H72 Z" fill="#2f9e44" />
							<rect x="85" y="326" width="10" height="12" fill="#fff" />
						</g>

						<!-- node: growth chart -->
						<g class="ci-node ci-float-a">
							<circle cx="430" cy="320" r="38" fill="#fff" stroke="url(#ci-g-green)" stroke-width="4" />
							<path d="M414 332 L424 322 L432 328 L446 310" fill="none" stroke="#2f9e44" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
							<path d="M440 310 h6 v6" fill="none" stroke="#2f9e44" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
						</g>

						<!-- node: academy (book) -->
						<g class="ci-node ci-float-b">
							<circle cx="260" cy="80" r="38" fill="#fff" stroke="url(#ci-g-yellow)" stroke-width="4" />
							<path d="M244 70 h14 v22 h-14 a2 2 0 0 1 0 -4 h10" fill="none" stroke="#e0a500" stroke-width="3.5" stroke-linejoin="round" />
							<path d="M276 70 h-14 v22 h14 a2 2 0 0 0 0 -4 h-10" fill="none" stroke="#e0a500" stroke-width="3.5" stroke-linejoin="round" />
						</g>
					</svg>
				</div>
			</div>
		</section>

		<!-- What is it -->
		<section class="section">
			<div class="container ci-intro">
				<div class="section-head">
					<h2>¿Qué es una <span class="grad-green">comunidad inteligente</span>?</h2>
					<p>
						Es un grupo de personas —una UNICA, banca comunal, junta o asociación— que gestiona
						su dinero, sus reglas y su crecimiento con tecnología. Ahorra en conjunto, se presta
						entre sí y aprende, todo desde un mismo lugar.
					</p>
				</div>
				<div class="ci-quote">
					<p>
						“No necesitas ser contador ni experto en finanzas. Solo necesitas tu comunidad.
						<strong>De lo demás nos encargamos juntos.</strong>”
					</p>
				</div>
			</div>
		</section>

		<!-- Pillars -->
		<section class="section section-alt" id="pilares">
			<div class="container">
				<div class="section-head">
					<h2>Todo lo que hace inteligente a tu comunidad</h2>
					<p>Cuatro pilares que convierten a un grupo cualquiera en una comunidad que prospera.</p>
				</div>

				<div class="ci-pillars">
					<article class="ci-pillar">
						<div class="ci-pillar-ic ic-green">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<h3>Sin conocimientos previos</h3>
						<p>
							La plataforma te guía en cada paso: crear la comunidad, sumar miembros, definir
							reglas y registrar aportes. Sin tecnicismos, sin papeleo, sin miedo a equivocarte.
						</p>
					</article>

					<article class="ci-pillar">
						<div class="ci-pillar-ic ic-yellow">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<h3>Una economía que se diferencia y prospera</h3>
						<p>
							El dinero se queda y circula dentro de tu comunidad. Los aportes, préstamos e
							intereses regresan a los miembros, no a un banco externo. Una economía propia,
							transparente y hecha para crecer de forma sostenible.
						</p>
					</article>

					<article class="ci-pillar">
						<div class="ci-pillar-ic ic-green">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<h3>Herramientas que hacen el trabajo pesado</h3>
						<p>
							Aportes, préstamos, cuotas e intereses calculados de forma automática. Cada
							movimiento queda registrado y todos ven la misma información desde su celular.
							Adiós al cuaderno y a las cuentas que no cuadran.
						</p>
					</article>

					<article class="ci-pillar">
						<div class="ci-pillar-ic ic-yellow">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422A12.083 12.083 0 0112 20.5 12.083 12.083 0 015.84 10.578L12 14z" /></svg>
						</div>
						<h3>Academia para crecer aprendiendo</h3>
						<p>
							Cursos y guías simples de ahorro, crédito e inversión, pensados para tu realidad.
							Tu comunidad no solo maneja mejor su dinero: aprende a hacerlo crecer.
						</p>
					</article>
				</div>

				<p class="ci-more">
					Y más: red de apoyo entre comunidades, foro integrado, marketplace comunitario y el
					<a href="/token">token AN</a> para potenciar todo el ecosistema.
				</p>
			</div>
		</section>

		<!-- How it works -->
		<section class="section">
			<div class="container">
				<div class="section-head">
					<h2>Crea la tuya en <span class="grad-green">3 pasos</span></h2>
					<p>Sin vueltas. Empiezas hoy y tu comunidad queda lista para crecer.</p>
				</div>
				<div class="ci-steps">
					<div class="ci-step">
						<span class="ci-step-n">1</span>
						<h3>Crea tu comunidad</h3>
						<p>Ponle nombre, invita a los miembros y define las reglas con la ayuda de la plataforma.</p>
					</div>
					<div class="ci-step">
						<span class="ci-step-n">2</span>
						<h3>Activa su economía</h3>
						<p>Registra aportes y préstamos. aquí nace calcula todo y mantiene las cuentas claras.</p>
					</div>
					<div class="ci-step">
						<span class="ci-step-n">3</span>
						<h3>Aprende y prospera</h3>
						<p>Usa la academia y las herramientas para hacer crecer el capital de tu comunidad.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Dark band CTA -->
		<section class="ci-band">
			<div class="band-orb" aria-hidden="true"></div>
			<div class="container ci-band-inner">
				<span class="wordmark on-dark band-mark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
				<h2>Tu comunidad tiene todo para <span class="grad-yellow">prosperar</span>.</h2>
				<p>
					Solo falta dar el primer paso. Crea una comunidad inteligente y deja que la tecnología,
					la academia y la red trabajen a tu favor.
				</p>
				<a href={WA} target="_blank" rel="noopener noreferrer" class="btn-yellow btn-yellow-lg">
					<svg class="wa-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
					Crea tu comunidad
				</a>
				<p class="ci-band-sub">
					¿Quieres entender el modelo a fondo? Lee
					<a href="/blog/como-son-comunidades-inteligentes-aqui-nace">cómo funcionan las comunidades inteligentes de aquí nace</a>.
				</p>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="site-footer">
		<div class="footer-inner">
			<div class="footer-brand">
				<span class="wordmark"><span class="wm-a">aquí</span><span class="wm-n">nace</span></span>
			</div>
			<p class="footer-copy">© 2026 aquí nace · Tu red financiera para crecer juntos</p>
			<div class="footer-links">
				<a href="/comunidades-inteligentes" class="footer-link">Comunidades</a>
				<a href="/blog" class="footer-link">Blog</a>
				<a href="/token" class="footer-link">Token</a>
				<a href="/privacidad" class="footer-link">Privacidad</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* ===== BACKGROUND BLOBS ===== */
	.bg-blobs {
		position: fixed;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
		z-index: -1;
	}
	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
	}
	.blob-1 {
		top: -12%;
		left: 15%;
		width: 620px;
		height: 620px;
		background: rgba(47, 158, 68, 0.1);
	}
	.blob-2 {
		bottom: 10%;
		right: -8%;
		width: 520px;
		height: 520px;
		background: rgba(245, 197, 24, 0.09);
	}
	.blob-3 {
		top: 45%;
		left: -8%;
		width: 420px;
		height: 420px;
		background: rgba(28, 90, 48, 0.07);
	}

	/* ===== NAVBAR ===== */
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid rgba(28, 90, 48, 0.08);
	}
	.navbar-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 14px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}
	.navbar-brand {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		flex-shrink: 0;
	}
	.navbar-brand .wordmark {
		font-size: 1.5rem;
	}
	.navbar-links {
		display: none;
		align-items: center;
		gap: 30px;
	}
	.navbar-link {
		color: var(--green-forest);
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		transition: color 0.25s;
	}
	.navbar-link:hover {
		color: var(--green-bright);
	}
	@media (min-width: 900px) {
		.navbar-links {
			display: flex;
		}
	}

	/* ===== BUTTONS ===== */
	.btn-yellow {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		padding: 14px 28px;
		background: var(--yellow);
		color: #3d2c00;
		font-weight: 700;
		border-radius: 9999px;
		font-size: 1rem;
		text-decoration: none;
		border: none;
		transition: all 0.3s;
		box-shadow: 0 8px 22px rgba(245, 197, 24, 0.35);
	}
	.btn-yellow:hover {
		background: #ffd633;
		transform: translateY(-2px);
		box-shadow: 0 14px 32px rgba(245, 197, 24, 0.45);
	}
	.btn-yellow:active {
		transform: translateY(0) scale(0.98);
	}
	.btn-yellow-sm {
		padding: 10px 20px;
		font-size: 0.9rem;
	}
	.btn-yellow-lg {
		padding: 18px 38px;
		font-size: 1.15rem;
	}
	.btn-ghost {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 28px;
		background: transparent;
		color: var(--green-forest);
